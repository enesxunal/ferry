{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Ferry Dev Server",
      "type": "shell",
      "command": "npm run dev -- --host 127.0.0.1",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "options": {
        "env": {
          "NO_COLOR": "1"
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "group": "dev"
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:\\s+http://127\\.0\\.0\\.1:5179/"
        }
      }
    }
  ]
}
